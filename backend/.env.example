# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_HOST=localhost
DB_NAME=Ticketing System
DB_PASSWORD=your_password_here
DB_PORT=5433

# In production set to true to require SSL on the DB connection.
# Set DB_SSL_REJECT_UNAUTHORIZED=false only when using a self-signed cert (e.g. RDS with custom CA).
DB_SSL_REJECT_UNAUTHORIZED=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_RANDOM_HEX_SECRET
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# Number of reverse-proxy hops in front of this server (e.g. 1 for nginx/ALB).
# Required for HTTPS redirect and accurate req.ip in production.
TRUST_PROXY=0

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# ── Rate limiting ─────────────────────────────────────────────────────────────
# General: all /api/ routes (IP-keyed)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Auth: login + token refresh (IP-keyed, tight)
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_MAX=10

# Account creation: POST /api/users (IP-keyed)
ACCOUNT_CREATE_WINDOW_MS=3600000
ACCOUNT_CREATE_MAX=20

# Ticket creation: POST /api/tickets (user-keyed)
TICKET_CREATE_WINDOW_MS=3600000
TICKET_CREATE_MAX=30

# Write mutations: PUT/DELETE on any resource (user-keyed)
WRITE_RATE_WINDOW_MS=60000
WRITE_RATE_MAX=30

# AI generation: POST /api/ai/* (user-keyed, tight)
AI_RATE_WINDOW_MS=60000
AI_RATE_MAX=5

# Read / list: GET on collections (user-keyed, anti-scraping)
READ_RATE_WINDOW_MS=60000
READ_RATE_MAX=60

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug  (default: info in prod, debug in dev)
LOG_LEVEL=info
# Directory where log files are written (created automatically if missing)
LOG_DIR=./logs
